# erxes — server-side (not exposed to browser)
ERXES_APP_TOKEN=your_erxes_app_token
GRAPHQL_URL=https://your-tenant.next.erxes.io/gateway/graphql

# erxes — client-side (exposed to browser)
NEXT_PUBLIC_ERXES_APP_TOKEN=your_erxes_app_token
NEXT_PUBLIC_ERXES_ENDPOINT=https://your-tenant.next.erxes.io/gateway/graphql
NEXT_PUBLIC_GRAPHQL_URL=https://your-tenant.next.erxes.io/gateway/graphql
